# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # qualifier.py + outreach.py (Claude)
OPENROUTER_API_KEY=sk-or-...          # optional model fallback

# ── LinkedIn / enrichment ─────────────────────────────────────────────────────
PROXYCURL_API_KEY=...                 # scraper.py + enricher.py (profile lookup)
DEBOUNCE_API_KEY=...                  # enricher.py (email validation)

# ── Email sending (outreach.py) ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com              # or smtp.sendgrid.net, etc.
SMTP_PORT=587                         # 587 = STARTTLS, 465 = SSL
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-app-password           # Gmail: use an App Password, not your login password
SMTP_FROM=Your Name <you@yourdomain.com>   # optional; defaults to SMTP_USER

# ── Cal.com (booker.py) ───────────────────────────────────────────────────────
CAL_COM_API_KEY=...                   # Settings → Developer → API Keys
CAL_COM_USERNAME=your-cal-username    # e.g. "alexsmith" (appears in your Cal.com URL)
CAL_COM_EVENT_SLUG=15min-discovery    # event type URL slug

# ── Database (optional) ───────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...
